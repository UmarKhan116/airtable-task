# ─────────────────────────────────────────────
#  Application
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─────────────────────────────────────────────
#  MongoDB
# ─────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/airtable_integration

# ─────────────────────────────────────────────
#  JWT (generate with: openssl rand -hex 64)
# ─────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────────
#  Airtable OAuth App
#  Register at: https://airtable.com/create/oauth
# ─────────────────────────────────────────────
AIRTABLE_CLIENT_ID=your_airtable_client_id
AIRTABLE_CLIENT_SECRET=your_airtable_client_secret
AIRTABLE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ─────────────────────────────────────────────
#  Airtable Scraping Credentials (Puppeteer)
#  These are encrypted at rest with AES-256
# ─────────────────────────────────────────────
AIRTABLE_EMAIL=your_airtable_email@example.com
AIRTABLE_PASSWORD=your_airtable_password

# AES-256 encryption key (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here

# ─────────────────────────────────────────────
#  Frontend URL (CORS)
# ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:4200

# ─────────────────────────────────────────────
#  Rate Limiting
# ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
